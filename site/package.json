    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.19.17",
    "axe-core": "^4.10.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
