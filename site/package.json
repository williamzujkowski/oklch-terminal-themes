{
  "name": "@williamzujkowski/oklch-terminal-themes-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "GitHub Pages theme picker for @williamzujkowski/oklch-terminal-themes.",
  "scripts": {
    "dev": "astro dev",
