---
import themes from '@williamzujkowski/oklch-terminal-themes/themes.json';
import { ALL_TAGS } from '@/lib/theme-filter';

// Selector owns primary + compare slots. Clicking a theme in the list picks it
// for whichever slot is currently "armed" (primary by default).
---

<section class="theme-selector" role="group" aria-label="Theme picker">
  <div class="row primary-row">
    <button type="button" class="nav" data-nav="prev" aria-label="Previous theme">
      <span aria-hidden="true">‹</span>
    </button>

    <div class="combobox" data-slot="a">
      <label class="visually-hidden" for="theme-combo-a">Active theme</label>
      <button
        type="button"
        class="combo-trigger"
        id="theme-combo-a"
        aria-haspopup="listbox"
        aria-expanded="false"
        data-slot="a"
      >
        <span class="combo-eyebrow">Theme</span>
        <span class="combo-label" data-combo-label>—</span>
        <span class="combo-meta" data-combo-meta>—</span>
        <span class="combo-caret" aria-hidden="true">▾</span>
      </button>
    </div>

    <button type="button" class="nav" data-nav="next" aria-label="Next theme">
      <span aria-hidden="true">›</span>
    </button>

    <button type="button" class="icon-btn" data-action="random" aria-label="Random theme"
      title="Surprise me">
      <span aria-hidden="true">✦</span>
    </button>

    <button
      type="button"
      class="icon-btn compare-toggle"
      data-action="compare-toggle"
      aria-pressed="false"
      title="Toggle side-by-side compare (c)"
    >
      <span class="label">Compare</span>
    </button>

    <details class="export-menu">
      <summary class="icon-btn" aria-label="Export this theme">
        <span aria-hidden="true">⎘</span>
        <span class="label">Export</span>
      </summary>
      <div class="export-body" role="menu">
        <button type="button" role="menuitem" data-export="css">
          <strong>CSS variables</strong><small>:root &lbrace; --terminal-… &rbrace;</small>
        </button>
        <button type="button" role="menuitem" data-export="tailwind">
          <strong>Tailwind v4</strong><small>@theme &lbrace; … &rbrace;</small>
        </button>
        <button type="button" role="menuitem" data-export="json">
          <strong>Raw JSON</strong><small>themes-slim shape</small>
        </button>
        <button type="button" role="menuitem" data-export="permalink">
          <strong>Permalink</strong><small>share this theme</small>
        </button>
      </div>
    </details>
  </div>

  <!-- Compare slot, revealed when compare mode is active. -->
  <div class="row compare-row" hidden>
    <button type="button" class="nav" data-nav="prev" data-slot="b" aria-label="Previous compare theme">
      <span aria-hidden="true">‹</span>
    </button>
    <div class="combobox" data-slot="b">
      <label class="visually-hidden" for="theme-combo-b">Compare theme</label>
      <button
        type="button"
        class="combo-trigger"
        id="theme-combo-b"
        aria-haspopup="listbox"
        aria-expanded="false"
        data-slot="b"
      >
        <span class="combo-eyebrow">Compare</span>
        <span class="combo-label" data-combo-label>—</span>
        <span class="combo-meta" data-combo-meta>—</span>
        <span class="combo-caret" aria-hidden="true">▾</span>
      </button>
    </div>
    <button type="button" class="nav" data-nav="next" data-slot="b" aria-label="Next compare theme">
      <span aria-hidden="true">›</span>
    </button>
  </div>

  <!-- Shared listbox panel used by whichever combo is open. -->
  <div
    id="theme-listbox"
    class="listbox"
    role="dialog"
    aria-label="Select theme"
    hidden
  >
    <div class="listbox-filters">
      <input
        id="theme-search"
        type="search"
        placeholder="Search 485 themes…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Search themes by name or slug"
      />
      <div class="listbox-tags" role="group" aria-label="Tag filters">
        {
          ALL_TAGS.map((tag) => (
            <button type="button" class="tag-chip" data-tag={tag} aria-pressed="false">
              {tag}
            </button>
          ))
        }
        <button type="button" class="tag-chip reset" data-action="reset-filters">
          clear
        </button>
      </div>
      <output class="listbox-count" id="listbox-count" aria-live="polite">
        {themes.length} themes
      </output>
    </div>
    <ul class="listbox-list" role="listbox" tabindex="-1">
      {
        themes
          .map((t) => ({
            slug: t.slug,
            name: t.name,
            isDark: t.isDark,
            tags: t.tags,
            search: `${t.name.toLowerCase()} ${t.slug}`,
            bg: t.colors.background.oklchCss,
            fg: t.colors.foreground.oklchCss,
            swatches: ['red', 'yellow', 'green', 'cyan', 'blue', 'purple'].map(
              (k) => t.colors[k as 'red'].oklchCss,
            ),
          }))
          .sort((a, b) => {
            const aPop = a.tags.includes('popular') ? 0 : 1;
            const bPop = b.tags.includes('popular') ? 0 : 1;
            return aPop - bPop || a.name.localeCompare(b.name);
          })
          .map((t) => (
            <li
              role="option"
              class="listbox-item"
              data-slug={t.slug}
              data-dark={t.isDark.toString()}
              data-tags={t.tags.join(' ')}
              data-search={t.search}
              aria-selected="false"
            >
              <span class="item-chip" style={`background:${t.bg};color:${t.fg}`}>
                <span
                  class="item-dot"
                  style={`background:${t.swatches[4] ?? t.fg}`}
                  aria-hidden="true"
                />
                {t.name}
              </span>
              <span class="item-swatches" aria-hidden="true">
                {t.swatches.map((c) => (
                  <span class="item-swatch" style={`background:${c}`} />
                ))}
              </span>
              {t.tags.includes('popular') && <span class="item-star">★</span>}
            </li>
          ))
      }
    </ul>
    <p class="listbox-empty" hidden>No themes match your filters.</p>
  </div>
</section>

<style>
  .theme-selector {
    position: relative;
    display: grid;
    gap: 0.5rem;
  }
  /* Astro's `display: grid` below wins over the user-agent `[hidden]` rule
     unless we opt back in explicitly. */
  [hidden] {
    display: none !important;
  }
  .row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto auto auto;
    gap: 0.4rem;
    align-items: stretch;
  }
  .compare-row {
    grid-template-columns: auto minmax(0, 1fr) auto;
  }

  .nav,
  .icon-btn {
    display: grid;
    place-items: center;
    gap: 0.4ch;
    grid-auto-flow: column;
    background: var(--surface);
    color: inherit;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    cursor: pointer;
    padding: 0 0.7rem;
    min-width: 2.25rem;
    font: inherit;
    font-size: 0.88rem;
    transition:
      background 100ms,
      border-color 100ms,
      color 100ms;
  }
  .nav:hover,
  .icon-btn:hover,
  .nav:focus-visible,
  .icon-btn:focus-visible {
    border-color: var(--accent);
    background: color-mix(in oklch, var(--accent) 12%, transparent);
  }
  .icon-btn:focus-visible,
  .nav:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .icon-btn .label {
    display: none;
  }
  @media (min-width: 52rem) {
    .icon-btn .label {
      display: inline;
    }
  }
  .compare-toggle[aria-pressed='true'] {
    background: color-mix(in oklch, var(--accent) 18%, transparent);
    color: var(--accent);
    border-color: var(--accent);
  }

  .combobox {
    position: relative;
  }
  .combo-trigger {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 0.65rem;
    align-items: baseline;
    width: 100%;
    padding: 0.5rem 0.85rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font: inherit;
    color: inherit;
    cursor: pointer;
    text-align: left;
  }
  .combo-trigger:hover,
  .combo-trigger:focus-visible,
  .combo-trigger[aria-expanded='true'] {
    border-color: var(--accent);
    background: color-mix(in oklch, var(--accent) 8%, transparent);
  }
  .combo-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .combo-eyebrow {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in oklch, var(--fg) 60%, transparent);
  }
  .combo-label {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .combo-meta {
    font-size: 0.78rem;
    color: color-mix(in oklch, var(--fg) 55%, transparent);
  }
  .combo-caret {
    font-size: 0.8rem;
    color: color-mix(in oklch, var(--fg) 60%, transparent);
  }

  .export-menu {
    position: relative;
  }
  .export-menu summary {
    list-style: none;
  }
  .export-menu summary::-webkit-details-marker {
    display: none;
  }
  .export-body {
    position: absolute;
    right: 0;
    top: calc(100% + 0.35rem);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.35rem;
    box-shadow: 0 8px 28px color-mix(in oklch, black 20%, transparent);
    display: grid;
    gap: 0.15rem;
    min-width: 14rem;
    z-index: 12;
  }
  .export-body button {
    text-align: left;
    display: grid;
    gap: 0.1rem;
    padding: 0.45rem 0.7rem;
    border-radius: 0.35rem;
    border: 1px solid transparent;
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: pointer;
  }
  .export-body button:hover,
  .export-body button:focus-visible {
    border-color: var(--accent);
    background: color-mix(in oklch, var(--accent) 10%, transparent);
  }
  .export-body button small {
    color: color-mix(in oklch, var(--fg) 55%, transparent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .listbox {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    right: 0;
    max-height: min(70vh, 32rem);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.6rem;
    box-shadow: 0 12px 32px color-mix(in oklch, black 25%, transparent);
    z-index: 20;
    display: grid;
    grid-template-rows: auto 1fr auto;
    overflow: hidden;
  }
  .listbox-filters {
    padding: 0.7rem 0.8rem 0.55rem;
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: minmax(12rem, 1fr) auto;
    grid-template-areas: 'search count' 'tags tags';
    gap: 0.5rem 0.75rem;
  }
  .listbox-filters input {
    grid-area: search;
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 0.4rem;
    background: var(--surface);
    color: var(--fg);
    font: inherit;
    font-size: 0.9rem;
  }
  .listbox-filters input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-color: var(--accent);
  }
  .listbox-tags {
    grid-area: tags;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .listbox-count {
    grid-area: count;
    font-size: 0.8rem;
    color: color-mix(in oklch, var(--fg) 60%, transparent);
    align-self: center;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .tag-chip {
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: inherit;
    cursor: pointer;
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }
  .tag-chip[aria-pressed='true'] {
    background: color-mix(in oklch, var(--accent) 15%, transparent);
    border-color: var(--accent);
    color: var(--accent);
  }
  .tag-chip.reset {
    border-style: dashed;
    color: color-mix(in oklch, currentColor 70%, transparent);
  }

  .listbox-list {
    list-style: none;
    margin: 0;
    padding: 0.25rem;
    overflow-y: auto;
  }
  .listbox-item {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 0.65rem;
    align-items: center;
    padding: 0.35rem 0.55rem;
    border-radius: 0.35rem;
    cursor: pointer;
    border: 1px solid transparent;
  }
  .listbox-item[aria-selected='true'],
  .listbox-item:hover,
  .listbox-item.is-active {
    border-color: color-mix(in oklch, var(--accent) 50%, var(--border));
    background: color-mix(in oklch, var(--accent) 10%, transparent);
  }
  .item-chip {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    padding: 0.2rem 0.55rem;
    border-radius: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .item-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .item-swatches {
    display: flex;
    gap: 2px;
  }
  .item-swatch {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 2px;
  }
  .item-star {
    color: oklch(0.8 0.18 70);
    font-size: 0.85rem;
    text-align: right;
  }

  .listbox-empty {
    padding: 1rem;
    text-align: center;
    font-size: 0.88rem;
    color: color-mix(in oklch, var(--fg) 60%, transparent);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
