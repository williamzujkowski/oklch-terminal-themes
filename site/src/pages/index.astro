---
import themes from '@williamzujkowski/oklch-terminal-themes/themes.json';
import slim from '@williamzujkowski/oklch-terminal-themes/themes-slim.json';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Showcase from '@/components/Showcase.astro';
import ShowcaseController from '@/components/ShowcaseController.astro';
import ThemeSelector from '@/components/ThemeSelector.astro';

const darkCount = themes.filter((t) => t.isDark).length;
const lightCount = themes.length - darkCount;
const popularCount = themes.filter((t) => t.tags.includes('popular')).length;

// Inline full themes-slim dataset — the controller reads it to apply colors on
// every selection change without another round-trip.
const slimJson = JSON.stringify(slim);
---

<BaseLayout title="OKLCH Terminal Themes — picker">
  <div class="site-shell">
    <section class="intro">
      <h1>OKLCH Terminal Themes</h1>
      <p class="tagline">
        Browse {themes.length} terminal color schemes in a live showcase — terminal,
        editor, reading, dashboard — swap themes with ←/→,
        <kbd>/</kbd> to search, <kbd>r</kbd> for a random pick.
      </p>
      <dl class="stats">
        <div><dt>total</dt><dd>{themes.length}</dd></div>
        <div><dt>dark</dt><dd>{darkCount}</dd></div>
        <div><dt>light</dt><dd>{lightCount}</dd></div>
        <div><dt>popular</dt><dd>{popularCount}</dd></div>
      </dl>
    </section>

    <ThemeSelector />

    <Showcase />

    <ShowcaseController />

    <script id="themes-data" is:inline type="application/json" set:html={slimJson} />
  </div>
</BaseLayout>

<style>
  .site-shell {
    display: grid;
    gap: 1.1rem;
    padding: 0.2rem 0 4rem;
  }
  .intro {
    padding: 1.75rem 0 0.5rem;
    text-align: center;
  }
  .intro h1 {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    margin: 0 0 0.4rem;
    letter-spacing: -0.02em;
  }
  .tagline {
    max-width: 46rem;
    margin: 0 auto 1.1rem;
    color: color-mix(in oklch, currentColor 72%, transparent);
    line-height: 1.55;
  }
  .tagline kbd {
    font-family: var(--font-mono);
    font-size: 0.8em;
    background: color-mix(in oklch, currentColor 10%, transparent);
    padding: 0 0.35rem;
    border-radius: 0.2rem;
    border: 1px solid color-mix(in oklch, currentColor 15%, transparent);
  }
  .stats {
    display: flex;
    gap: 1.3rem;
    justify-content: center;
    flex-wrap: wrap;
    margin: 0;
  }
  .stats div {
    display: grid;
    gap: 0.15rem;
  }
  .stats dt {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: color-mix(in oklch, currentColor 60%, transparent);
  }
  .stats dd {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    font-variant-numeric: tabular-nums;
  }
</style>
