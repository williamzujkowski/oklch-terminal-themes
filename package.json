{
  "name": "@williamzujkowski/oklch-terminal-themes",
  "version": "0.1.0",
  "description": "Canonical dataset of 485 terminal color schemes converted to OKLCH, with WCAG contrast data per theme — npm package + JSON API for Astro, Svelte, Tailwind v4, and theme pickers.",
  "type": "module",
  "license": "MIT",
  "author": "William Zujkowski",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamzujkowski/oklch-terminal-themes.git"
  },
  "homepage": "https://github.com/williamzujkowski/oklch-terminal-themes#readme",
  "bugs": {
    "url": "https://github.com/williamzujkowski/oklch-terminal-themes/issues"
  },
  "keywords": [
    "oklch",
    "terminal",
    "colors",
    "themes",
    "ansi",
    "culori",
    "tailwind",
    "palette"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./themes.json": "./data/themes.json",
    "./themes-slim.json": "./data/themes-slim.json",
    "./index.json": "./data/index.json",
    "./themes/*": "./data/by-name/*"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build:data": "tsx scripts/build.ts",
    "build:ts": "tsc -p tsconfig.json",
    "build": "pnpm build:data && pnpm build:ts",
    "update": "tsx scripts/fetch-upstream.ts && pnpm build:data",
    "validate": "tsx scripts/validate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!**/node_modules/**\" \"!**/dist/**\" \"!**/data/**\" \"!**/upstream/**\" \"!**/coverage/**\" \"!**/.astro/**\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,js,json,yml,yaml,md}": "prettier --write",
    "*.ts": "eslint --fix",
    "*.md": "markdownlint-cli2 --fix"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "culori": "^4.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "js-yaml@<4.1.1": "^4.1.1",
      "markdown-it@<14.1.1": "^14.1.1",
      "smol-toml@<1.6.1": "^1.6.1"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0"
}
